# Smart Scraper production environment template
# Copy to `.env.production` for local staging, but store real production secrets in Railway/Vercel variables.

# ==========================================
# CORE CONFIGURATION
# ==========================================

ENVIRONMENT=production
DEBUG=false
RELOAD=false
APP_NAME=Smart Scraper Platform
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# ==========================================
# SECURITY
# ==========================================

SECRET_KEY=replace-with-a-long-random-32-plus-char-secret
API_KEY=your-production-api-key-here
API_KEY_HEADER_NAME=X-API-Key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# DATABASE (Supabase)
# ==========================================

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ==========================================
# REDIS (Upstash)
# ==========================================

REDIS_URL=redis://default:PASSWORD@HOST:6379
REDIS_CONNECT_TIMEOUT=5

# ==========================================
# CELERY
# ==========================================

CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270

# ==========================================
# REQUEST & RATE LIMITS
# ==========================================

REQUEST_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_BYTES=1048576
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
JOB_CREATE_RATE_LIMIT=20
JOB_CREATE_RATE_WINDOW_SECONDS=3600
RUN_CREATE_RATE_LIMIT=20
RUN_CREATE_RATE_WINDOW_SECONDS=60

# ==========================================
# CORS
# ==========================================

CORS_ORIGINS=https://app.example.com,https://www.app.example.com

# ==========================================
# STORAGE
# ==========================================

STORAGE_ROOT=/data/storage
EXPORT_RETENTION_HOURS=168

# ==========================================
# PLAYWRIGHT
# ==========================================

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# ==========================================
# AI SERVICES
# ==========================================

ANALYSIS_MODE=basic
OPENAI_API_KEY=your-openai-api-key-here

# ==========================================
# MONITORING (Sentry)
# ==========================================

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==========================================
# AUTHENTICATION (Clerk)
# ==========================================

CLERK_SECRET_KEY=sk_test_your-clerk-secret-key-here

# ==========================================
# DEPLOYMENT URLs
# ==========================================

FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-app.railway.app

# ==========================================
# VALIDATION CHECKLIST
# ==========================================
# [ ] SECRET_KEY: 32-character random string generated
# [ ] API_KEY: Strong production API key created
# [ ] DATABASE_URL: Valid Supabase PostgreSQL URL
# [ ] REDIS_URL: Valid Upstash Redis URL
# [ ] OPENAI_API_KEY: Valid OpenAI API key
# [ ] SENTRY_DSN: Valid Sentry DSN
# [ ] CLERK_SECRET_KEY: Valid Clerk secret key
# [ ] FRONTEND_URL: Set after Vercel deployment
# [ ] BACKEND_URL: Set after Railway deployment
OPENAI_API_KEY=
GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PROVIDER_API_KEY_ENCRYPTION_KEY=
