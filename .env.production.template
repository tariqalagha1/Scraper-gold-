# =============================================================================
# Smart Scraper Platform - PRODUCTION Environment Variables
# =============================================================================
# This file should be managed by your secrets vault (Kubernetes, Vault, etc.)
# NEVER commit real secrets to version control.
# =============================================================================

# =============================================================================
# PostgreSQL Database (REPLACE WITH REAL VALUES)
# =============================================================================
POSTGRES_USER=scraper
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN
POSTGRES_DB=scraper
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://scraper:REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN@postgres:5432/scraper

# =============================================================================
# Redis (REPLACE WITH REAL VALUES)
# =============================================================================
REDIS_URL=redis://:REPLACE_WITH_STRONG_REDIS_PASSWORD@redis:6379/0
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_CONNECT_TIMEOUT=5.0

# =============================================================================
# Security (GENERATE NEW VALUES)
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
# Generate with: openssl rand -hex 16
API_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_16
API_KEY_HEADER_NAME=X-API-Key

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# =============================================================================
# AI API Keys (REMOVE IF UNUSED, ADD REAL KEYS IF NEEDED)
# =============================================================================
OPENAI_API_KEY=sk-REAL_OPENAI_KEY_HERE_OR_EMPTY
GEMINI_API_KEY=REAL_GEMINI_KEY_HERE_OR_EMPTY

# =============================================================================
# Playwright Configuration
# =============================================================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
REQUEST_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_BYTES=1048576

# =============================================================================
# Scraping Configuration
# =============================================================================
SCRAPER_RATE_LIMIT=2
SCRAPER_MAX_CONCURRENT=5
SCRAPER_BASE_URL=http://scraper-smart:8000
SCRAPER_API_KEY=REPLACE_WITH_SMART_SCRAPER_API_KEY_OR_EMPTY
SCRAPER_TIMEOUT_SECONDS=30.0

# =============================================================================
# CORS Configuration (PRODUCTION ONLY)
# =============================================================================
# Set to your actual domain, NOT localhost
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Disable CORS origin regex in production
CORS_ORIGIN_REGEX=

# =============================================================================
# Security Policies
# =============================================================================
BLOCK_PRIVATE_NETWORK_TARGETS=true
ALLOW_LOOPBACK_TARGETS_IN_NON_PRODUCTION=false
ENABLE_SECURITY_HEADERS=true
ENABLE_PROMPT_INJECTION_GUARD=true
SECURITY_PROMPT_MAX_CHARS=4000
SECURITY_PROMPT_BLOCK_THRESHOLD=3

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW_SECONDS=300
AUTH_REGISTER_RATE_LIMIT=3
AUTH_REGISTER_RATE_WINDOW_SECONDS=3600
JOB_CREATE_RATE_LIMIT=5
JOB_CREATE_RATE_WINDOW_SECONDS=3600
RUN_CREATE_RATE_LIMIT=5
RUN_CREATE_RATE_WINDOW_SECONDS=60

# =============================================================================
# Storage Paths
# =============================================================================
STORAGE_RAW_HTML=/app/storage/raw_html
STORAGE_SCREENSHOTS=/app/storage/screenshots
STORAGE_PROCESSED=/app/storage/processed
STORAGE_EXPORTS=/app/storage/exports
EXPORT_RETENTION_HOURS=168

# =============================================================================
# Logging and Monitoring
# =============================================================================
LOG_LEVEL=WARNING
LOG_FORMAT=json
ENVIRONMENT=production
DEBUG=false
RELOAD=false

# =============================================================================
# AI Analysis Configuration
# =============================================================================
ENABLE_VECTOR=false
ANALYSIS_MODE=basic
OPENAI_ORCHESTRATION_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Service Configuration
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# Error Tracking (OPTIONAL: Configure Sentry for production monitoring)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# Timeouts
# =============================================================================
ORCHESTRATION_NODE_TIMEOUT_SECONDS=90
ORCHESTRATION_INTAKE_TIMEOUT_SECONDS=30
ORCHESTRATION_SCRAPER_TIMEOUT_SECONDS=180
ORCHESTRATION_PROCESSING_TIMEOUT_SECONDS=60
ORCHESTRATION_VECTOR_TIMEOUT_SECONDS=45
ORCHESTRATION_ANALYSIS_TIMEOUT_SECONDS=45
ORCHESTRATION_EXPORT_TIMEOUT_SECONDS=45

# =============================================================================
# Admin Settings
# =============================================================================
SYSTEM_KEYS_ADMIN_EMAILS=admin@yourdomain.com
PROVIDER_API_KEY_ENCRYPTION_KEY=

# =============================================================================
# Database Connection Pool (Tune for your load)
# =============================================================================
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_CONNECT_MAX_RETRIES=3
DATABASE_CONNECT_RETRY_DELAY=1.0
