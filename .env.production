# =============================================================================
# SMART SCRAPER SERVICE CONFIGURATION (macOS Docker - Use host.docker.internal)
# =============================================================================
# OPTION A: External Joulaa on host machine (macOS Docker)
# Use host.docker.internal to reach services on macOS host
SCRAPER_BASE_URL=http://host.docker.internal:8000

# OPTION B: Joulaa in separate docker-compose (same Docker network)
# SCRAPER_BASE_URL=http://joulaa-backend:8000

# OPTION C: Disable/External (uncomment if using different service)
# SCRAPER_BASE_URL=

# =============================================================================
# AI PROVIDERS (Optional - leave empty if unused)
# =============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# PLAYWRIGHT & SCRAPING
# =============================================================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
REQUEST_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_BYTES=1048576

# =============================================================================
# RATE LIMITING
# =============================================================================
SCRAPER_RATE_LIMIT=2
SCRAPER_MAX_CONCURRENT=5
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW_SECONDS=300
AUTH_REGISTER_RATE_LIMIT=5
AUTH_REGISTER_RATE_WINDOW_SECONDS=3600
JOB_CREATE_RATE_LIMIT=10
JOB_CREATE_RATE_WINDOW_SECONDS=3600
RUN_CREATE_RATE_LIMIT=10
RUN_CREATE_RATE_WINDOW_SECONDS=60

# =============================================================================
# CORS (Keep localhost for now - update for production domain)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=

# =============================================================================
# SECURITY POLICIES
# =============================================================================
BLOCK_PRIVATE_NETWORK_TARGETS=true
ALLOW_LOOPBACK_TARGETS_IN_NON_PRODUCTION=true
ENABLE_SECURITY_HEADERS=true
ENABLE_PROMPT_INJECTION_GUARD=true
SECURITY_PROMPT_MAX_CHARS=4000
SECURITY_PROMPT_BLOCK_THRESHOLD=3

# =============================================================================
# STORAGE
# =============================================================================
STORAGE_RAW_HTML=./backend/storage/raw_html
STORAGE_SCREENSHOTS=./backend/storage/screenshots
STORAGE_PROCESSED=./backend/storage/processed
STORAGE_EXPORTS=./backend/storage/exports
EXPORT_RETENTION_HOURS=168

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG=false
RELOAD=false

# =============================================================================
# APPLICATION
# =============================================================================
ENVIRONMENT=production
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# AI ANALYSIS (Disabled by default)
# =============================================================================
ENABLE_VECTOR=false
ANALYSIS_MODE=basic
OPENAI_ORCHESTRATION_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# TIMEOUTS
# =============================================================================
SCRAPER_TIMEOUT_SECONDS=30.0
ORCHESTRATION_NODE_TIMEOUT_SECONDS=90
ORCHESTRATION_INTAKE_TIMEOUT_SECONDS=30
ORCHESTRATION_SCRAPER_TIMEOUT_SECONDS=180
ORCHESTRATION_PROCESSING_TIMEOUT_SECONDS=60
ORCHESTRATION_VECTOR_TIMEOUT_SECONDS=45
ORCHESTRATION_ANALYSIS_TIMEOUT_SECONDS=45
ORCHESTRATION_EXPORT_TIMEOUT_SECONDS=45

# =============================================================================
# DATABASE POOLING
# =============================================================================
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_CONNECT_MAX_RETRIES=3
DATABASE_CONNECT_RETRY_DELAY=1.0

# =============================================================================
# ADMIN
# =============================================================================
SYSTEM_KEYS_ADMIN_EMAILS=[]
PROVIDER_API_KEY_ENCRYPTION_KEY=

# =============================================================================
# ERROR TRACKING (Optional)
