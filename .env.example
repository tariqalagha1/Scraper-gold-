# =============================================================================
# Smart Scraper Platform - Root Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env file with real credentials to version control.
# =============================================================================

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper_password_change_me
POSTGRES_DB=scraper_db
POSTGRES_PORT=5432

# Full database URL (used by backend)
DATABASE_URL=postgresql+asyncpg://scraper:scraper_password_change_me@localhost:5432/scraper_db

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT=5.0

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_KEY=dev-api-key-change-me
API_KEY_HEADER_NAME=X-API-Key

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# AI API Keys
# =============================================================================
# OpenAI API Key (for embeddings and analysis)
OPENAI_API_KEY=sk-your-openai-api-key

# Google Gemini API Key (alternative AI provider)
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# Playwright Configuration
# =============================================================================
# Run browser in headless mode (true for production)
PLAYWRIGHT_HEADLESS=true

# Browser timeout in milliseconds
PLAYWRIGHT_TIMEOUT=30000
REQUEST_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_BYTES=1048576

# =============================================================================
# Scraping Configuration
# =============================================================================
# Default rate limit (requests per second)
SCRAPER_RATE_LIMIT=2

# Maximum concurrent scraping sessions
SCRAPER_MAX_CONCURRENT=5

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Service Ports
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# =============================================================================
# Storage Paths
# =============================================================================
STORAGE_RAW_HTML=./backend/storage/raw_html
STORAGE_SCREENSHOTS=./backend/storage/screenshots
STORAGE_PROCESSED=./backend/storage/processed
STORAGE_EXPORTS=./backend/storage/exports

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
# Enable vector embeddings and semantic search
ENABLE_VECTOR=false
# Set to ai to use OpenAI for summaries/insights.
# This can use either OPENAI_API_KEY from env or a user-saved OpenAI key from the app.
ANALYSIS_MODE=basic
OPENAI_ORCHESTRATION_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EXPORT_RETENTION_HOURS=168
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
CELERY_TASK_SOFT_TIME_LIMIT=270
CELERY_TASK_TIME_LIMIT=300

# =============================================================================
# Development Settings
# =============================================================================
DEBUG=false
RELOAD=true
