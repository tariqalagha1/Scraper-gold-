# Smart Scraper Frontend Environment Variables
# Copy this file to .env and fill in the values

# API URL - Backend server URL
REACT_APP_API_URL=http://127.0.0.1:8001/api/v1
# Optional fixed API key for trusted local/dev setups only.
# Leave empty for normal dashboard auth and per-user key management.
REACT_APP_API_KEY=
REACT_APP_API_KEY_HEADER_NAME=X-API-Key
# Optional localhost-only fallback key when REACT_APP_API_KEY is unset.
REACT_APP_LOCAL_DEV_BOOTSTRAP_API_KEY=

# App Name (optional - for display purposes)
REACT_APP_NAME=Smart Scraper

# Debug Mode (optional - set to 'true' for development)
REACT_APP_DEBUG=false
